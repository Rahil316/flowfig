{
  "name": "flowfig",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "flowfig",
      "workspaces": [
        "packages/*"
      ]
    },
    "node_modules/@flowfig/agent-kit": {
      "resolved": "packages/agent-kit",
      "link": true
    },
    "node_modules/@flowfig/core": {
      "resolved": "packages/core",
      "link": true
    },
    "node_modules/@flowfig/extension": {
      "resolved": "packages/extension",
      "link": true
    },
    "node_modules/@flowfig/figma-plugin": {
      "resolved": "packages/figma-plugin",
      "link": true
    },
    "packages/agent-kit": {
      "name": "@flowfig/agent-kit",
      "version": "0.0.0"
    },
    "packages/core": {
      "name": "@flowfig/core",
      "version": "0.0.0"
    },
    "packages/extension": {
      "name": "@flowfig/extension",
      "version": "0.0.0"
    },
    "packages/figma-plugin": {
      "name": "@flowfig/figma-plugin",
      "version": "0.0.0"
    }
  }
}
